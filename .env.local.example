# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token
GITHUB_REPOS=owner/repo1,owner/repo2

# Notion
NOTION_TOKEN=ntn_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_discord_server_id
DISCORD_CHANNEL_ID=your_discord_channel_id

# Figma
FIGMA_TOKEN=figd_your_figma_personal_access_token
FIGMA_FILE_KEY=your_figma_file_key

# Upstash Redis (선택 — Rate limiting용)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# AI (선택)
GROQ_API_KEY=gsk_your_groq_api_key

# 클라이언트 공개 변수
NEXT_PUBLIC_DISCORD_VOICE_URL=https://discord.com/channels/SERVER_ID/CHANNEL_ID
