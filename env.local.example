# GitHub Personal Access Token
# https://github.com/settings/tokens/new (repo 권한 체크)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# Notion Integration Token
# https://www.notion.so/my-integrations 에서 생성
# DB 페이지 우측 상단 "연결 추가" 로 Integration 연결 필요
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Discord Bot Token
# https://discord.com/developers/applications 에서 Bot 생성
# Bot을 서버에 초대하고 채널 ID 복사 (개발자 모드에서 우클릭)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Figma Personal Access Token
# https://www.figma.com/settings → Personal access tokens
# File Key: Figma 파일 URL의 /file/{FILE_KEY}/... 부분
FIGMA_TOKEN=
FIGMA_FILE_KEY=
